{
  "criteria": {
    "use_item": {
      "trigger": "using_item",
      "conditions": {
        "item": {
          "predicates": {
            "custom_data": {
              "reef": {
                "item": {
                  "id": "reef:remote",
                  "components": {
                    "reef:link": {
                      "linked": false
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "rewards": {
    "function": "reef:api/remote/unlinked_remote/listener"
  }
}
