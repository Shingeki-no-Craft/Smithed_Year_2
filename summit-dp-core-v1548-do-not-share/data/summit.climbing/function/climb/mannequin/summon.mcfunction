$summon minecraft:mannequin ~ ~-0.25 ~ {Tags:["summit.climbing.mannequin","summit.climbing.current_main","summit.climbing.entity"],NoGravity: 1b,immovable: 1b,Invulnerable: 1b,pose: "crouching",profile:{id:$(UUID)},equipment: {mainhand:{components:{"minecraft:item_model":"minecraft:air"},count:1,id:"minecraft:acacia_boat"},offhand:{components:{"minecraft:item_model":"minecraft:air"},count:1,id:"minecraft:acacia_boat"}},Rotation:[$(rotation),-40.0f]}
