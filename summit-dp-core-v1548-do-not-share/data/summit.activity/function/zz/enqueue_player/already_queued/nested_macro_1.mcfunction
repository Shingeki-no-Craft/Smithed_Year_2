$dialog show @s { "type": "minecraft:confirmation", "title": "Switch Queue?", "body": { "type": "minecraft:plain_message", "contents": [ "You are currently queued for ", $(current_activity_name), " from ", $(current_booth_name), ".", "\n\n", "Do you want to switch to being queued for ", $(new_activity_name), " from ", $(new_booth_name), "?" ] }, "yes": { "label": "Yes", "action": { "type": "minecraft:run_command", "command": "trigger summit.activity.swap set 1" } }, "no": { "label": "No", "action": { "type": "minecraft:run_command", "command": "trigger summit.activity.swap set -1" } } }
return 2
