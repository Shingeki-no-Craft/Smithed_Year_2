advancement revoke @s only snc:mannequin/odmtrack_suggester
execute if entity @s[advancements={snc:odm_get=false}] run function snc:dynamic/dialog_box {name:{text:"Sld. Dano",color:green}, line_1:["You haven't received your",{"text":" ODM Gear ","color":"dark_red"},"yet!"], line_2:[{text:"Go see "},{"text":"Gen. Energy","color":"dark_green"}," [",{"player":"Energy2468",color:white},{text:"\uF82C",font:"snc:gui"}, "] to claim your equipment."], line_3:["","Look for him on the exterior to get geared up."], sound:"entity.villager.ambient master @s ~ ~ ~ 1 0.8"}

execute if entity @s[advancements={snc:odm_get=true}] unless score @s snc.quest.odmtrack matches 1 run function snc:dynamic/dialog_box {name:{text:"Sld. Dano",color:green}, line_1:["You've got your",{"text":" ODM Gear ","color":"dark_red"},"! Now, head over to"], line_2: ["",{"text":"Gen. Hope","color":"dark_green"}," [",{"player":"HopeEllie",color:white},{text:"\uF82C",font:"snc:gui"}, "]. She'll guide you on how you can improve"], line_3:["","your mobility."], sound:"entity.villager.ambient master @s ~ ~ ~ 1 0.8"}

execute if score @s snc.quest.odmtrack matches 1 run function snc:dynamic/dialog_box {name:{text:"Sld. Dano",color:green}, line_1:["Look at you! You've mastered the ",{"text":"ODM Gear","color":"dark_red"},"!"], line_2: ["Don't let those skills rust... Head out to the ",{"text":"battlegrounds","color":"dark_red"}], line_3:["and show everyone what a true ",{"text":"scout","color":"dark_green"}," can do!"], sound:"entity.villager.ambient master @s ~ ~ ~ 1 0.8"}