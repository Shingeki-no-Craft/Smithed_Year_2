##### HOW TO CREATE A SHIFTER #####
execute as @s[tag=snc.shifter.cart] run function snc:shifters/mobs/main with storage minecraft:cart
execute as @s[tag=snc.shifter.colossal] run function snc:shifters/mobs/main with storage minecraft:colossal
execute as @s[tag=snc.shifter.attack] run function snc:shifters/mobs/main with storage minecraft:attack
execute as @s[tag=snc.shifter.beast] run function snc:shifters/mobs/main with storage minecraft:beast
execute as @s[tag=snc.shifter.armor] run function snc:shifters/mobs/main with storage minecraft:armor
execute as @s[tag=snc.shifter.jaw] run function snc:shifters/mobs/main with storage minecraft:jaw
execute as @s[tag=snc.shifter.female] run function snc:shifters/mobs/main with storage minecraft:female