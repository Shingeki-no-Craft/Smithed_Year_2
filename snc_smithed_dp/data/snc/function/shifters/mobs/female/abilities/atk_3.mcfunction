# If config is enabled AND is in berserk mode then skip
execute if score $berserk female_vars matches 0 run return -1

$execute unless score state female_vars matches 18..19 run item replace entity @s container.2 with quartz[enchantment_glint_override=true,minecraft:item_model="snc:female/item/4",custom_data={female_atk_3:1b,atk_shifter:1b,$(id)_titan:1b, summit: {droppable: {callback: true}}},custom_name={translate:aot.ability.retribution_kick,color:dark_purple,italic:false},lore=[{translate:aot.ability.retribution_kick.desc,color:yellow},{text:" "},{translate:aot.active,color:gray,italic:false},[{translate:aot.titan.female,color:blue,bold:true,italic:false},{text:" "},{translate:aot.ability.retribution_kick.desc2,color:blue,bold:false,italic:false}],{translate:aot.ability.retribution_kick.desc3,color:blue,bold:false,italic:false},{translate:aot.ability.retribution_kick.desc4,color:blue,bold:false,italic:false},{translate:aot.ability.retribution_kick.desc5,color:blue,bold:false,italic:false},{text:" "},[{translate:aot.active.invulnerability,color:gold,italic:false}],[{"text":"$(damage_counter)","color":"gold","italic":false}," ",{"translate":"aot.active.damage"}],[{"text":"$(cooldown_counter)s","color":"gold","italic":false}," ",{"translate":"snc.cooldown"}]],consumable={sound:"minecraft:block.wool.fall","consume_seconds":0},use_cooldown={seconds:$(cooldown_counter),cooldown_group:"snc:female_atk_3"}]

$execute if score state female_vars matches 18..19 run item replace entity @s container.2 with quartz[enchantment_glint_override=true,minecraft:item_model="snc:female/item/6",custom_data={female_atk_3:1b,atk_shifter:1b,$(id)_titan:1b, summit: {droppable: {callback: true}}},custom_name={translate:aot.ability.retribution_kick,color:dark_purple,italic:false},lore=[{translate:aot.ability.retribution_kick.desc,color:yellow},{text:" "},{translate:aot.active,color:gray,italic:false},[{translate:aot.titan.female,color:blue,bold:true,italic:false},{text:" "},{translate:aot.ability.retribution_kick.desc2,color:blue,bold:false,italic:false}],{translate:aot.ability.retribution_kick.desc3,color:blue,bold:false,italic:false},{translate:aot.ability.retribution_kick.desc4,color:blue,bold:false,italic:false},{translate:aot.ability.retribution_kick.desc5,color:blue,bold:false,italic:false},{text:" "},[{translate:aot.active.invulnerability,color:gold,italic:false}],[{"text":"$(damage_counter)","color":"gold","italic":false}," ",{"translate":"aot.active.damage"}],[{"text":"$(cooldown_counter)s","color":"gold","italic":false}," ",{"translate":"snc.cooldown"}]],consumable={sound:"minecraft:block.wool.fall","consume_seconds":0},use_cooldown={seconds:1}]