# If config is enabled AND is in berserk mode then skip
$execute if score $shifter_berserk config matches 1 if score $berserk female_vars matches 0 run item replace entity @s container.1 with quartz[enchantment_glint_override=true,minecraft:item_model="shifters/female/item/3",custom_data={female_atk_2:1b,atk_shifter:1b,$(id)_titan:1b},custom_name={translate:aot.ability.perfect_strike,color:dark_purple,italic:false},lore=[{translate:aot.ability.perfect_strike.desc,color:yellow},{translate:aot.ability.perfect_strike.desc2,color:yellow},{text:" "},{translate:aot.active,color:gray,italic:false},[{translate:aot.titan.female,color:blue,bold:true,italic:false},{text:" "},{translate:aot.ability.perfect_strike.desc3,color:blue,bold:false,italic:false}],{translate:aot.ability.perfect_strike.desc4,color:blue,bold:false,italic:false},{translate:aot.ability.perfect_strike.desc5,color:blue,bold:false,italic:false},{text:" "},[{"text":"$(damage_strike_1)","color":"gold","italic":false}," ",{"translate":"aot.active.damage"}],[{"text":"$(cooldown_strike_1)s","color":"gold","italic":false}," ",{"translate":"snc.cooldown"}]],consumable={sound:"minecraft:block.wool.fall","consume_seconds":0},use_cooldown={seconds:1,cooldown_group:"snc:female_atk_2_1"}]
